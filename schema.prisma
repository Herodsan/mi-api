generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  creadoEn  DateTime @default(now())
}

model Resultado {
  id             Int      @id @default(autoincrement())
  nombre         String
  verbal         Int
  logicoMat      Int
  visualEsp      Int
  kinestesica    Int
  musical        Int
  intrapersonal  Int
  interpersonal  Int
  creadoEn       DateTime @default(now())
}
